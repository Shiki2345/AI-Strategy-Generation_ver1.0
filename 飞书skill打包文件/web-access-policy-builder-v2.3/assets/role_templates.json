{
  "description": "基于角色的批量权限策略，一个角色对应一条策略，管理员无需策略",
  "url_module_mapping": {
    "账户/用户权限管理": [
      "https://*.amazon.*/sw/AccountInfo*",
      "https://*.amazon.*/user-manager*"
    ],
    "商品管理(Inventory)": [
      "https://*.amazon.*/inventory*",
      "https://*.amazon.*/product-search*"
    ],
    "广告": [
      "https://*.amazon.*/advertising/*",
      "https://advertising.amazon.com/*"
    ],
    "买家消息(Communication)": [
      "https://*.amazon.*/messaging/inbox*"
    ],
    "订单(Orders)": [
      "https://*.amazon.*/orders-v3*"
    ],
    "财务/资金": [
      "https://*.amazon.*/payments*",
      "https://*.amazon.*/gp/payments-account/*"
    ],
    "业务报告": [
      "https://*.amazon.*/business-reports*"
    ],
    "发货计划(Shipment Plan)": [
      "https://*.amazon.*/fba/sendtoamazon*"
    ]
  },
