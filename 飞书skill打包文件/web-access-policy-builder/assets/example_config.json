{
  "policy_id": "WEB_ACCESS_POLICY_001_SOC_001",
  "policy_name": "工作时间社交媒体访问限制策略",
  "policy_type": "specific_website",
  "description": "在工作时间限制员工访问社交媒体网站，提高工作效率",
  "status": "active",
  "created_at": "2026-04-10T10:15:55+08:00",
  "created_by": "何青杨 (qingyang_he@fzzixun.com)",
  
  "target_users": {
    "scope": "all_employees",
    "exclusions": ["ceo"],
    "includes_contractors": false,
    "includes_interns": true,
    "includes_remote_employees": true,
    "includes_temporary": false,
    "departments": []
  },
  
  "schedule": {
    "timezone": "Asia/Shanghai",
    "recurrence": "weekly",
    "weekdays": ["monday", "tuesday", "wednesday", "thursday", "friday"],
    "weekend_days": ["saturday", "sunday"],
    "time_ranges": [
      {
        "start": "09:00",
        "end": "18:00"
      }
    ],
    "exclude_holidays": true,
    "holiday_schedule": "national_holidays",
    "special_dates": {
      "exclusions": [],
      "inclusions": []
    }
  },
  
  "restrictions": {
    "type": "website_blocking",
    "websites": [
      {
        "domain": "weibo.com",
        "name": "微博",
        "block_type": "complete",
        "subdomains": ["*.weibo.com"],
        "notes": "社交媒体平台"
      },
      {
        "domain": "douyin.com",
        "name": "抖音网页版",
        "block_type": "complete",
        "subdomains": ["*.douyin.com"],
        "notes": "短视频平台"
      },
      {
        "domain": "xiaohongshu.com",
        "name": "小红书",
        "block_type": "complete",
        "subdomains": ["*.xiaohongshu.com"],
        "notes": "社交电商平台"
      },
      {
        "domain": "facebook.com",
        "name": "Facebook",
        "block_type": "complete",
        "subdomains": ["*.facebook.com"],
        "notes": "国际社交媒体"
      },
      {
        "domain": "twitter.com",
        "name": "Twitter/X",
        "block_type": "complete",
        "subdomains": ["*.twitter.com"],
        "notes": "社交媒体平台"
      },
      {
        "domain": "instagram.com",
        "name": "Instagram",
        "block_type": "complete",
        "subdomains": ["*.instagram.com"],
        "notes": "图片社交平台"
      }
    ],
    "block_level": "domain_level",
    "exceptions": {
      "allowed_urls": [],
      "allowed_ips": [],
      "allowed_users": [],
      "business_purposes": ["市场推广", "客户服务", "品牌监测"]
    },
    "category": "social_media",
    "severity": "high"
  },
  
  "approval_process": {
    "required": true,
    "approver": "ceo",
    "method": "online",
    "max_duration_hours": 4,
    "requires_reason": true,
    "auto_revoke_after_hours": 8,
    "notification_channels": ["email", "im", "notification_center"],
    "escalation_policy": "manager_chain",
    "approval_form": {
      "fields": ["申请原因", "预计时长", "业务价值", "相关部门"],
      "attachments": ["业务说明文档"],
      "approval_steps": 1
    },
    "audit_trail": true
  },
  
  "enforcement": {
    "action": "block_with_notification",
    "notification_message": "当前为工作时间，根据公司《网页访问管理规定》，访问社交媒体网站需要特殊审批。如需访问，请通过内部系统申请临时权限。",
    "redirect_url": null,
    "logging_level": "detailed",
    "grace_period_minutes": 5,
    "remediation_steps": [
      "通过内部系统申请临时访问权限",
      "联系直属主管说明工作需求",
      "联系IT支持部门处理特殊情况"
    ],
    "compliance_level": "strict",
    "enforcement_mode": "real_time",
    "user_feedback": true
  },
  
  "monitoring": {
    "alert_threshold": 5,
    "report_frequency": "weekly",
    "notify_admins": ["it_department", "hr_department", "security_team"],
    "metrics": [
      "access_attempts",
      "approval_requests",
      "approval_approvals",
      "approval_rejections",
      "violations",
      "grace_period_usage"
    ],
    "retention_days": 90,
    "analytics": {
      "trend_analysis": true,
      "anomaly_detection": true,
      "department_insights": true
    },
    "compliance_reports": {
      "generate": true,
      "frequency": "monthly",
      "recipients": ["management", "compliance_team"]
    }
  },
  
