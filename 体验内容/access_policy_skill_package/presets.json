        {"url_rule": "www.amazon.com/gp/cart/*", "说明": "购物车页面", "verified": "partial"},
        {"url_rule": "www.amazon.com/gp/buy/spc*", "说明": "旧版结账页（兜底）", "verified": false}
      ],
      "tags": ["亚马逊", "买家号", "结账", "高风险"]
